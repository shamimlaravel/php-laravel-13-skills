    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "laravel-13",
        "php-attributes",
        "php-8",
        "refactor",
        "eloquent",
        "queue",
        "commands",
        "ai",
        "skill"
    ],
    "homepage": "https://github.com/shamimlaravel/php-laravel-13-skills",
    "authors": [
        {
            "name": "Shamim",
            "email": "shamimstack@gmail.com",
            "role": "developer"
        }
    ],
    "support": {
        "issues": "https://github.com/shamimlaravel/php-laravel-13-skills/issues",
